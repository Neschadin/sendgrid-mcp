{
  "name": "sendgrid-mcp",
  "version": "1.0.0",
  "description": "SendGrid MCP Server — templates, preflight send, diagnostics, account & console settings",
  "type": "module",
  "license": "MIT",
  "author": "Neschadin",
  "repository": {
    "type": "git",
    "url": "https://github.com/Neschadin/sendgrid-mcp.git"
  },
  "homepage": "https://github.com/Neschadin/sendgrid-mcp#readme",
  "bugs": {
    "url": "https://github.com/Neschadin/sendgrid-mcp/issues"
  },
  "keywords": [
    "mcp",
    "sendgrid",
    "twilio",
    "email",
    "transactional-email",
    "model-context-protocol"
  ],
  "bin": {
    "sendgrid-mcp": "bin/sendgrid"
  },
  "files": [
    "bin/sendgrid",
    "MCP_TOOLS.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build --compile src/index.ts --outfile bin/sendgrid",
    "build:release": "bash scripts/build-release.sh",
    "inspect": "bunx @modelcontextprotocol/inspector bun src/index.ts",
    "typecheck": "bun build src/index.ts --outdir .tmp-typecheck --target bun",
    "typecheck:tsc": "NODE_OPTIONS=--max-old-space-size=8192 tsc --noEmit --skipLibCheck",
    "lint": "oxlint",
    "smoke": "bun run scripts/smoke-register-tools.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "oxlint": "1.71.0",
    "typescript": "6.0.3"
  }
}
