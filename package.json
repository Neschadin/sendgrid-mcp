{
  "name": "sendgrid-mcp",
  "version": "1.0.0",
  "description": "SendGrid MCP Server — template management, test sends, diagnostics",
  "type": "module",
  "bin": {
    "sendgrid-tool": "src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build --compile src/index.ts --outfile bin/sendgrid-tool",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "bun-types": "1.3.11",
    "typescript": "5.9.3"
  }
}
